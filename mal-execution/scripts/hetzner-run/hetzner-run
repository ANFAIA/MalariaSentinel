# --- arg parsing -----------------------------------------------------------

# Global flag parsing happens inline in main() (see below). The
# HETZNER_RUN_DRY_RUN / HETZNER_RUN_DEBUG variables are set there and read
# by every subcommand + helper.

# --- subcommand dispatch ---------------------------------------------------

cmd_start() {
  local type="ccx33" name="" location="fsn1" image="ubuntu-24.04" ssh_key=""
  while (( $# )); do
    case "$1" in
      --type)      type="$2"; shift 2 ;;
      --name)      name="$2"; shift 2 ;;
      --location)  location="$2"; shift 2 ;;
      --image)     image="$2"; shift 2 ;;
      --ssh-key)   ssh_key="$2"; shift 2 ;;
      -h|--help)   print_start_help; return 0 ;;
      *) die "start: unknown flag: $1" ;;
    esac
  done
  if [[ -z "$name" ]]; then
    name="ms-$(date +%s)-$$"
  fi
  ssh_key="$(resolve_ssh_key_name "$ssh_key")"
  start_vm "$name" "$type" "$image" "$location" "$ssh_key"
}

cmd_stop() {
  if (( $# == 0 )); then die "stop: missing <name>"; fi
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_stop_help; return 0
  fi
  stop_vm "$1"
}

cmd_destroy() {
  if (( $# == 0 )); then die "destroy: missing <name>"; fi
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_destroy_help; return 0
  fi
  destroy_vm "$1"
}

cmd_status() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_status_help; return 0
  fi
  if (( $# == 0 )); then
    list_vms
  else
    status_vm "$1"
  fi
}

cmd_exec() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_exec_help; return 0
  fi
  (( $# >= 2 )) || die "exec: usage: hetzner-run exec <name> <cmd...>"
  local name="$1"; shift
  exec_remote "$name" "$@"
}

cmd_push() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_push_help; return 0
  fi
  (( $# == 3 )) || die "push: usage: hetzner-run push <name> <local> <remote>"
  push_path "$1" "$2" "$3"
}

cmd_pull() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_pull_help; return 0
  fi
  (( $# == 3 )) || die "pull: usage: hetzner-run pull <name> <remote> <local>"
  pull_path "$1" "$2" "$3"
}

cmd_sim_run() {
  local name="" repo="mal-ghana-sim" data="./data/ghana" cmd=""
  local pull_to="" keep_vm=0
  while (( $# )); do
    case "$1" in
      --name)     name="$2"; shift 2 ;;
      --repo)     repo="$2"; shift 2 ;;
      --data)     data="$2"; shift 2 ;;
      --cmd)      cmd="$2"; shift 2 ;;
      --pull-to)  pull_to="$2"; shift 2 ;;
      --keep-vm)  keep_vm=1; shift ;;
      --yes)      HETZNER_RUN_ASSUME_YES=1; shift ;;
      -h|--help)  print_sim_run_help; return 0 ;;
      *) die "sim-run: unknown flag: $1" ;;
    esac
  done
  if [[ -z "$name" ]]; then
    name="ms-$(date +%s)-$$"
  fi
  if [[ -z "$pull_to" ]]; then
    pull_to="./runs/$(date +%Y-%m-%dT%H-%M-%S)"
  fi
  if [[ -z "$cmd" ]]; then
    cmd="cd /work/code/mal-ghana-sim && uv sync && uv run python scripts/03_simulate.py"
  fi
  sim_run "$name" "$repo" "$data" "$cmd" "$pull_to" "$keep_vm"
}

cmd_train() {
  local name="" repo="mal-ghana-sim" data="./data/ghana" config=""
  local pull_to="" keep_vm=0
  while (( $# )); do
    case "$1" in
      --name)     name="$2"; shift 2 ;;
      --repo)     repo="$2"; shift 2 ;;
      --data)     data="$2"; shift 2 ;;
      --config)   config="$2"; shift 2 ;;
      --pull-to)  pull_to="$2"; shift 2 ;;
      --keep-vm)  keep_vm=1; shift ;;
      -h|--help)  print_train_help; return 0 ;;
      *) die "train: unknown flag: $1" ;;
    esac
  done
  if [[ -z "$name" ]]; then
    name="ms-$(date +%s)-$$"
  fi
  if [[ -z "$pull_to" ]]; then
    pull_to="./runs/$(date +%Y-%m-%dT%H-%M-%S)"
  fi
  train_run "$name" "$repo" "$data" "$config" "$pull_to" "$keep_vm"
}

cmd_cost() {
  local type="" hours="" do_list=0
  while (( $# )); do
    case "$1" in
      --type)  type="$2"; shift 2 ;;
      --hours) hours="$2"; shift 2 ;;
      --list)  do_list=1; shift ;;
      -h|--help) print_cost_help; return 0 ;;
      *) die "cost: unknown flag: $1" ;;
    esac
  done

  if (( do_list )); then
    printf '%s' "$PRICE_TABLE_EUR_PER_HOUR" | jq -r 'to_entries | sort_by(.key) | .[] | "\(.key | . + ("        " | .[0:8])) €\(.value)"'
    return 0
  fi

  [[ -n "$type" ]] || die "cost: --type required (or pass --list)"
  [[ -n "$hours" ]] || die "cost: --hours required (or pass --list)"
  local c
  c="$(calc_cost "$type" "$hours")" || die "cost: cannot compute for type='$type'"
  printf '€%s\n' "$c"
}

# --- main dispatch ---------------------------------------------------------

main() {
  if (( $# == 0 )); then
    print_main_help
    exit 0
  fi

  # Strip global flags (--dry-run / --debug) from the front. We do this
  # inline (not via a command substitution) so the side-effect of setting
  # HETZNER_RUN_DRY_RUN/HETZNER_RUN_DEBUG is visible in the rest of main().
  local -a remaining=()
  while (( $# )); do
    case "$1" in
      --dry-run) HETZNER_RUN_DRY_RUN=1; shift ;;
      --debug)   HETZNER_RUN_DEBUG=1; shift ;;
      *)         remaining+=("$1"); shift ;;
    esac
  done
  set -- "${remaining[@]}"

  if (( $# == 0 )); then
    print_main_help
    exit 0
  fi

  local sub="$1"; shift
  case "$sub" in
    -h|--help|help) print_main_help ;;
    start)          cmd_start "$@" ;;
    stop)           cmd_stop "$@" ;;
    destroy)        cmd_destroy "$@" ;;
    status)         cmd_status "$@" ;;
    exec)           cmd_exec "$@" ;;
    push)           cmd_push "$@" ;;
    pull)           cmd_pull "$@" ;;
    sim-run)        cmd_sim_run "$@" ;;
    train)          cmd_train "$@" ;;
    cost)           cmd_cost "$@" ;;
    *) die "unknown subcommand: $sub (try: hetzner-run --help)" ;;
  esac
}

main "$@"
