#!/usr/bin/env bash
# hetzner-run — ephemeral Hetzner Cloud VM runner for MalariaSentinel jobs.
#
# Subcommands: start | stop | destroy | status | exec | push | pull |
#             sim-run | train | cost | --help
# Global flag: --dry-run (prints hcloud / rsync / ssh invocations; no real
#                       API or network calls).

set -euo pipefail

HETZNER_RUN_DEBUG="${HETZNER_RUN_DEBUG:-0}"

# Locate the package root (handles symlinks, absolute invocations, etc.).
_hetzner_run_self_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -h "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  local sdir
  sdir="$(cd -P "$(dirname "$src")" && pwd)"
  (cd "$sdir" && pwd)
}
HETZNER_RUN_ROOT="$(_hetzner_run_self_dir)"
HETZNER_RUN_LIB="$HETZNER_RUN_ROOT/lib"
export HETZNER_RUN_ROOT HETZNER_RUN_LIB

# shellcheck source=lib/common.sh
source "$HETZNER_RUN_LIB/common.sh"
# shellcheck source=lib/vm.sh
source "$HETZNER_RUN_LIB/vm.sh"
# shellcheck source=lib/sync.sh
source "$HETZNER_RUN_LIB/sync.sh"
# shellcheck source=lib/jobs.sh
source "$HETZNER_RUN_LIB/jobs.sh"

# --- help text -------------------------------------------------------------

print_main_help() {
  cat <<'EOF'
hetzner-run — start, use, and tear down ephemeral Hetzner Cloud VMs

USAGE
  hetzner-run [--dry-run] <subcommand> [flags] [args]

GLOBAL FLAGS
  --dry-run        Print the hcloud / rsync / ssh commands that would run.
                   No API calls, no network calls.
  --debug          Verbose logging.
  -h, --help       Show this help.

SUBCOMMANDS
  start            Create a new VM and wait for SSH.
  stop             Gracefully shut down an existing VM.
  destroy          Delete a VM and remove its local cache.
  status [<name>]  Show one VM's status, or list all VMs with prefix ms-*.
  exec <name> <c>  Run a command on the VM (stream output, preserve exit code).
  push <name> <l> <r>   rsync a local path to a remote path on the VM.
  pull <name> <r> <l>   rsync a remote path on the VM to a local path.
  sim-run          Boot a ccx33, push repo+data, run a sim, pull results, destroy.
  train            Boot a ccx33, push repo+data+config, train, pull results, destroy.
  cost             Cost calculator (--type X --hours Y or --list).

EXAMPLES
  hetzner-run --dry-run start --type ccx33 --name ms-test
  hetzner-run start --type ccx33 --name ms-1
  hetzner-run exec ms-1 'df -h /'
  hetzner-run push ms-1 ./mal-ghana-sim /work/code/mal-ghana-sim
  hetzner-run pull ms-1 /work/runs ./runs/2026-07-13
  hetzner-run destroy ms-1

See `hetzner-run <subcommand> --help` for subcommand-specific flags.
EOF
}

