#!/usr/bin/env bash
# tools/hitl/hooks/pre-commit
# Backstop for the protected-files policy. The primary enforcement is the
# agent reading AGENTS.md; this hook catches the case where the agent
# commits without asking.
#
# Install once per clone:
#   make -f tools/hitl/Makefile install-hooks
# (or copy this file to .git/hooks/pre-commit manually)
#
# Behaviour:
#   - Reads tools/hitl/.protected
#   - Lists the staged files via `git diff --cached --name-only`
#   - For each staged file that matches a protected pattern, aborts the
#     commit unless the commit message contains the literal
#     `protected-edit-approved`.
#   - Bypasses gracefully if git is not available or this is not a git
#     repo (the agent-level policy is the only enforcement then).

set -uo pipefail

# --- find the project root by walking up from BASH_SOURCE[0] until we
# find a directory that contains tools/hitl/. This works whether the
# hook lives in tools/hitl/hooks/ (the source) or in .git/hooks/ (the
# installed location, after `make install-hooks`).
find_tools_hitl() {
  local d
  d="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  while [ "$d" != "/" ]; do
    if [ -d "$d/tools/hitl" ] && [ -f "$d/tools/hitl/.protected" ]; then
      echo "$d/tools/hitl"
      return 0
    fi
    d="$(dirname "$d")"
  done
  return 1
}

if ! TOOLS_HITL="$(find_tools_hitl)"; then
  echo "pre-commit: cannot locate tools/hitl/ — is this the right repo?" >&2
  exit 0
fi
# TOOLS_HITL is .../<project>/tools/hitl. The project root is two levels up.
PROJECT_ROOT="$(cd "$TOOLS_HITL/../.." && pwd)"

PROTECTED="$TOOLS_HITL/.protected"

# --- guards ---
command -v git >/dev/null 2>&1 || exit 0
[ -d "$PROJECT_ROOT/.git" ] || exit 0
[ -f "$PROTECTED" ] || { echo "pre-commit: missing $PROTECTED" >&2; exit 1; }

cd "$PROJECT_ROOT"

# --- load protected list (bash 3.2 compatible — no mapfile) ---
PROTECTED_PATTERNS=""
while IFS= read -r line; do
  case "$line" in
    '' | '#'* | '//'* | '<!--'*) continue ;;
  esac
  PROTECTED_PATTERNS="${PROTECTED_PATTERNS}${line}"$'\n'
done < "$PROTECTED"

# --- list staged files ---
STAGED=""
STAGED="$(git diff --cached --name-only --diff-filter=ACMRT 2>/dev/null)"

# --- find protected files that are staged ---
violations=""
while IFS= read -r f; do
  [ -z "$f" ] && continue
  while IFS= read -r pat; do
    [ -z "$pat" ] && continue
    # shellcheck disable=SC2053
    if [[ "$f" == $pat ]]; then
      violations="${violations}${f}"$'\n'
      break
    fi
  done <<< "$PROTECTED_PATTERNS"
done <<< "$STAGED"

[ -z "$violations" ] && exit 0

# --- check the allowances file for each violation ---
ALLOWANCES="$TOOLS_HITL/.protected-allowances"
ALLOWED_PATTERNS=""
if [ -f "$ALLOWANCES" ]; then
  while IFS= read -r line; do
    case "$line" in
    '' | '#'* | '//'* | '<!--'*) continue ;;
  esac
    ALLOWED_PATTERNS="${ALLOWED_PATTERNS}${line}"$'\n'
  done < "$ALLOWANCES"
fi

_is_allowed() {
  local p="$1"
  local pat
  while IFS= read -r pat; do
    [ -z "$pat" ] && continue
    # shellcheck disable=SC2053
    [[ "$p" == $pat ]] && return 0
  done <<< "$ALLOWED_PATTERNS"
  return 1
}

still_blocked=""
while IFS= read -r f; do
  [ -z "$f" ] && continue
  if ! _is_allowed "$f"; then
    still_blocked="${still_blocked}${f}"$'\n'
  fi
done <<< "$violations"

if [ -z "$still_blocked" ]; then
  echo "pre-commit: protected files modified, but covered by .protected-allowances — proceeding"
  exit 0
fi

{
  echo "pre-commit: refusing to commit protected files without explicit override."
  echo
  echo "  Modified protected files:"
  printf '    - %s\n' $still_blocked
  echo
  echo "  These files are reusable project infrastructure. Per AGENTS.md, they"
  echo "  require human-in-the-loop approval before modification."
  echo
  echo "  To proceed, do ONE of:"
  echo "    1. Add a one-off allowance (recommended for this session):"
  echo "         make -f tools/hitl/Makefile protected-allow P=<path>"
  echo "       (repeat for each path; or add a glob to the allowances file)"
  echo
  echo "    2. Skip this hook (use sparingly; the agent is not supposed to do"
  echo "       this without user approval):"
  echo "         git commit --no-verify"
} >&2
exit 1
