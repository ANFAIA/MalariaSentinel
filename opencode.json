{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["agents/loops/AGENTS.md"],
  "permission": {
    "edit": {
      "AGENTS.md": "ask",
      ".gitignore": "ask",
      "opencode.json": "ask",
      "agents/memory/.project": "ask"
    },
    "bash": {
      "*": "allow",
      "make -f agents/memory/scripts/Makefile wipe *": "deny",
      "make -f agents/memory/scripts/Makefile set-project *": "deny",
      "*make*wipe*": "deny",
      "*make*set-project*": "deny"
    },
    "webfetch": "allow",
    "todowrite": "allow",
    "question": "allow",
    "memory_node": "ask",
    "memory_rel": "ask",
    "memory_query": "allow",
    "memory_audit": "allow",
    "memory_seed": "ask",
    "memory_status": "allow"
  },
  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "ask",
          "test-fixer": "allow",
          "code-reviewer": "ask",
          "doc-researcher": "ask",
          "security-auditor": "ask"
        }
      }
    }
  }
}
