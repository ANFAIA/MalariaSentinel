{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["agents/loops/AGENTS.md"],
  "default_agent": "supervisor",
  "permission": {
    "edit": {
      "AGENTS.md": "ask",
      ".gitignore": "ask",
      "opencode.json": "ask",
      "agents/memory/.project": "ask"
    },
    "bash": {
      "*": "allow",
      "make -f agents/memory/scripts/Makefile wipe *": "deny",
      "make -f agents/memory/scripts/Makefile set-project *": "deny",
      "*make*wipe*": "deny",
      "*make*set-project*": "deny",
      "rm *": "ask",
      "rmdir *": "ask",
      "git push *": "ask",
      "git checkout *": "ask"
    },
    "webfetch": "allow",
    "todowrite": "allow",
    "question": "allow",
    "memory_node": "ask",
    "memory_rel": "ask",
    "memory_query": "allow",
    "memory_audit": "allow",
    "memory_seed": "ask",
    "memory_status": "allow",
    "external_directory": "ask"
  },
  "agent": {
    "supervisor": {
      "description": "Primary orchestrator. Delegates to loops and subagents, isolates edit-work via the gitagent skill. Plan-like baseline.",
      "permission": {
        "*": "deny",
        "task": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash":{
          "*": "deny",
          "gitagents *": "allow"
        }
      }
    },
    "test-fixer": {
      "description": "Iterates a check command until it exits 0. Proactive on test failures.",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": {
          "*": "ask",
          "uv run pytest *": "allow",
          "git diff *": "allow",
          "git status *": "allow",
          "git log *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "allow",
        "question": "allow"
      }
    },
    "code-reviewer": {
      "description": "Reviews code changes against project conventions. Read-only: returns findings, does not modify files.",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": {
          "*": "ask",
          "git diff *": "allow",
          "git log *": "allow"
        },
        "webfetch": "ask",
        "websearch": "deny",
        "question": "allow"
      }
    },
    "doc-researcher": {
      "description": "Searches the knowledge base in Neo4j first; web is a fallback. Returns a brief, not raw content.",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow"
      }
    },
    "security-auditor": {
      "description": "OWASP Top 10 audit. Read-only: returns findings list, no file edits or network calls.",
      "mode": "subagent",
      "model": {
        "modelID": "claude-sonnet-4-20250514",
        "providerID": "anthropic"
      },
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "question": "allow"
      }
    }
  }
}
