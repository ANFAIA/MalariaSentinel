{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "supervisor",
  "permission": {
    "edit": {
      "AGENTS.md": "ask",
      ".gitignore": "ask",
      "opencode.json": "ask",
      "agents/memory/.project": "ask",
      "data/": "ask"
    },
    "bash": {
      "*": "allow",
      "make -f agents/memory/scripts/Makefile wipe *": "deny",
      "make -f agents/memory/scripts/Makefile set-project *": "deny",
      "*make*wipe*": "deny",
      "*make*set-project*": "deny",
      "rm *": "ask",
      "rmdir *": "ask",
      "git push *": "ask",
      "git checkout *": "ask"
    },
    "webfetch": "allow",
    "todowrite": "allow",
    "question": "allow",
    "memory_node": "ask",
    "memory_rel": "ask",
    "memory_query": "allow",
    "memory_audit": "allow",
    "memory_seed": "ask",
    "memory_status": "allow",
    "external_directory": {
      "~/Downloads/MalariaSentinel/*": "allow",
      "*": "ask"
    }
  },
  "agent": {
    "supervisor": {
      "description": "Primary orchestrator. Delegates to loops and subagents, isolates edit-work via the gitagent skill. Plan-like baseline.",
      "permission": {
        "task": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "allow",

          "sudo rm *": "ask",
          "sudo rm -rf *": "ask",
          "rm -rf *": "ask",
          "rm -rf /": "ask",
          "rm -rf --no-preserve-root /": "ask",

          "dd * /dev/sd*": "ask",
          "dd * /dev/nvme*": "ask",
          "dd * /dev/disk*": "ask",
          "mkfs* /dev/sd*": "ask",
          "mkfs* /dev/nvme*": "ask",
          "mkfs* /dev/disk*": "ask",

          "chmod -R * /*": "ask",
          "chown -R * /*": "ask",
          "chgrp -R * /*": "ask",

          "*> /etc/*": "ask",
          "*> /var/log/*": "ask",
          "*> /System/*": "ask",
          "*> /Library/*": "ask",

          "curl * | sh": "ask",
          "curl * | bash": "ask",
          "wget * | sh": "ask",
          "wget * | bash": "ask",

          ":(){ :|:& };:": "ask",

          "crontab -r": "ask",

          "gitagents *": "allow"
        }
      }
    },
    "test-fixer": {
      "description": "Iterates a check command until it exits 0. Proactive on test failures.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/test-fixer.md}",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": {
          "*": "ask",
          "uv run pytest *": "allow",
          "git diff *": "allow",
          "git status *": "allow",
          "git log *": "allow",
          "make -f agents/memory/scripts/Makefile wipe *": "deny",
          "make -f agents/memory/scripts/Makefile set-project *": "deny",
          "*make*wipe*": "deny",
          "*make*set-project*": "deny"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "allow",
        "question": "allow"
      }
    },
    "code-reviewer": {
      "description": "Reviews code changes against project conventions. Read-only: returns findings, does not modify files.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/code-reviewer.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": {
          "*": "ask",
          "git diff *": "allow",
          "git log *": "allow",
          "make -f agents/memory/scripts/Makefile wipe *": "deny",
          "make -f agents/memory/scripts/Makefile set-project *": "deny",
          "*make*wipe*": "deny",
          "*make*set-project*": "deny"
        },
        "webfetch": "ask",
        "websearch": "deny",
        "question": "allow"
      }
    },
    "doc-researcher": {
      "description": "Searches the knowledge base in Neo4j first; web is a fallback. Returns a brief, not raw content.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/doc-researcher.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": {
          "*": "ask",
          "make -f agents/memory/scripts/Makefile wipe *": "deny",
          "make -f agents/memory/scripts/Makefile set-project *": "deny",
          "*make*wipe*": "deny",
          "*make*set-project*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow"
      }
    },
    "security-auditor": {
      "description": "OWASP Top 10 audit. Read-only: returns findings list, no file edits or network calls.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/security-auditor.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "question": "allow"
      }
    }
  }
}
