{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "supervisor",
  "permission": {
    "edit": {
      "AGENTS.md": "ask",
      ".gitignore": "ask",
      "opencode.json": "ask",
      "agents/memory/.project": "ask",
      "data/": "ask"
    },
    "bash": {
      "*": "allow",
      "make -f agents/memory/scripts/Makefile wipe *": "deny",
      "make -f agents/memory/scripts/Makefile set-project *": "deny",
      "*make*wipe*": "deny",
      "*make*set-project*": "deny",
      "rm *": "ask",
      "rmdir *": "ask",
      "git push *": "ask",
      "git checkout *": "ask"
    },
    "webfetch": "allow",
    "todowrite": "allow",
    "question": "allow",
    "memory_node": "ask",
    "memory_rel": "ask",
    "memory_query": "allow",
    "memory_recall": "allow",
    "memory_audit": "allow",
    "memory_seed": "ask",
    "memory_status": "allow",
    "external_directory": {
      "~/Downloads/MalariaSentinel/*": "allow",
      "*": "ask"
    }
  },
  "agent": {
    "supervisor": {
      "description": "Primary orchestrator. Delegates to loops and subagents, isolates edit-work via the gitagent skill. Reads the knowledge graph; does NOT write to it (delegates writes to memory-curator). Plan-like baseline.",
      "permission": {
        "task": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "memory_node": "deny",
        "memory_rel": "deny",
        "memory_query": "allow",
        "memory_recall": "allow",
        "memory_audit": "allow",
        "memory_seed": "deny",
        "memory_status": "allow",
        "bash": {
          "*": "allow",

          "sudo rm *": "ask",
          "sudo rm -rf *": "ask",
          "rm -rf *": "ask",
          "rm -rf /": "ask",
          "rm -rf --no-preserve-root /": "ask",

          "dd * /dev/sd*": "ask",
          "dd * /dev/nvme*": "ask",
          "dd * /dev/disk*": "ask",
          "mkfs* /dev/sd*": "ask",
          "mkfs* /dev/nvme*": "ask",
          "mkfs* /dev/disk*": "ask",

          "chmod -R * /*": "ask",
          "chown -R * /*": "ask",
          "chgrp -R * /*": "ask",

          "*> /etc/*": "ask",
          "*> /var/log/*": "ask",
          "*> /System/*": "ask",
          "*> /Library/*": "ask",

          "curl * | sh": "ask",
          "curl * | bash": "ask",
          "wget * | sh": "ask",
          "wget * | bash": "ask",

          ":(){ :|:& };:": "ask",

          "crontab -r": "ask",

          "gitagents *": "allow"
        }
      }
    },
    "test-fixer": {
      "description": "Iterates a check command until it exits 0. Proactive on test failures.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/test-fixer.md}",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "memory_node": "deny",
        "memory_rel": "deny",
        "memory_query": "allow",
        "memory_recall": "allow",
        "memory_audit": "allow",
        "memory_seed": "deny",
        "memory_status": "allow",
        "bash": {
          "*": "ask",
          "uv run pytest *": "allow",
          "git diff *": "allow",
          "git status *": "allow",
          "git log *": "allow",
          "make -f agents/memory/scripts/Makefile wipe *": "deny",
          "make -f agents/memory/scripts/Makefile set-project *": "deny",
          "*make*wipe*": "deny",
          "*make*set-project*": "deny"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "allow",
        "question": "allow"
      }
    },
    "code-reviewer": {
      "description": "Reviews code changes against project conventions. Read-only: returns findings, does not modify files.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/code-reviewer.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "memory_node": "deny",
        "memory_rel": "deny",
        "memory_query": "allow",
        "memory_recall": "allow",
        "memory_audit": "allow",
        "memory_seed": "deny",
        "memory_status": "allow",
        "bash": {
          "*": "ask",
          "git diff *": "allow",
          "git log *": "allow",
          "make -f agents/memory/scripts/Makefile wipe *": "deny",
          "make -f agents/memory/scripts/Makefile set-project *": "deny",
          "*make*wipe*": "deny",
          "*make*set-project*": "deny"
        },
        "webfetch": "ask",
        "websearch": "deny",
        "question": "allow"
      }
    },
    "doc-researcher": {
      "description": "Searches the knowledge base in Neo4j first; web is a fallback. Returns a brief, not raw content.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/doc-researcher.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "memory_node": "deny",
        "memory_rel": "deny",
        "memory_query": "allow",
        "memory_recall": "allow",
        "memory_audit": "allow",
        "memory_seed": "deny",
        "memory_status": "allow",
        "bash": {
          "*": "ask",
          "make -f agents/memory/scripts/Makefile wipe *": "deny",
          "make -f agents/memory/scripts/Makefile set-project *": "deny",
          "*make*wipe*": "deny",
          "*make*set-project*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow"
      }
    },
    "security-auditor": {
      "description": "OWASP Top 10 audit. Read-only: returns findings list, no file edits or network calls.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/security-auditor.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "question": "allow"
      }
    },
    "memory-curator": {
      "description": "The single writer to the project knowledge graph. Loads project-memory skill first. Reads for recall, writes via memory_node / memory_rel (ask — supervisor approves each), and re-embeds when embeddings are missing. Never uses mcp__add_memory source:json. See agents/loops/memory-curator.md for the full contract.",
      "mode": "subagent",
      "prompt": "{file:agents/loops/memory-curator.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "memory_node": "ask",
        "memory_rel": "ask",
        "memory_query": "allow",
        "memory_recall": "allow",
        "memory_audit": "allow",
        "memory_seed": "ask",
        "memory_status": "allow",
        "bash": {
          "*": "ask",
          "bash agents/memory/scripts/memory.sh *": "ask",
          "bash agents/memory/scripts/recall.sh *": "allow",
          "bash agents/memory/scripts/reembed.sh *": "ask",
          "bash agents/memory/scripts/audit.sh *": "allow",
          "bash agents/memory/scripts/seed.sh *": "ask",
          "neo4j-cli query *": "allow",
          "neo4j-cli query * --rw *": "ask",
          "make -f agents/memory/scripts/Makefile wipe *": "deny",
          "make -f agents/memory/scripts/Makefile set-project *": "deny",
          "*make*wipe*": "deny",
          "*make*set-project*": "deny"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "question": "allow"
      }
    },
    "research-runner": {
      "description": "Focused worker for the research_harness/ pipeline. Pre-approves websearch, webfetch, and bash calls needed to run `uv run python -m agents.research_harness.run` and read/write papers/. Does NOT edit any file outside papers/. Used as primary agent via `opencode run --agent research-runner`. Also handles memory evaluation after each phase.",
      "mode": "primary",
      "prompt": "You are a research executor. Your job is to run the MalariaSentinel research harness cycle (search → write → review → hypothesize) and report back. Use the CLI: `uv run python -m agents.research_harness.run --mode <search|condense|review|hypothesize> --topic '<topic>'`. The harness itself calls opencode internally with --auto and --title, so you do not need to handle those flags. Do not edit any file outside papers/. Return a structured summary of what each phase produced, paths to files written, and any errors.",
      "permission": {
        "edit": {
          "papers/": "allow",
          "*": "deny"
        },
        "bash": {
          "*": "ask",
          "uv run python -m agents.research_harness.run *": "allow",
          "uv run python -m agents.research_harness.run": "allow",
          "ls papers/*": "allow",
          "cat papers/*": "allow",
          "head papers/*": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "memory_node": "allow",
        "memory_rel": "allow",
        "memory_query": "allow",
        "memory_recall": "allow",
        "memory_audit": "allow",
        "memory_status": "allow",
        "question": "allow"
      }
    },
    "improvement-agent": {
      "description": "Reviews the output of a complete research cycle and auto-applies improvements to prompts, tools, skills, and papers. Records improvements in the knowledge graph. Can edit agents/research_harness/, papers/, and opencode.json (for skill/agent config only).",
      "mode": "primary",
      "prompt": "{file:agents/loops/improvement-agent.md}",
      "permission": {
        "edit": {
          "agents/research_harness/": "allow",
          "papers/": "allow",
          "opencode.json": "ask",
          "*": "deny"
        },
        "bash": {
          "*": "ask",
          "bash agents/research_harness/scripts/install_skills.sh": "allow",
          "uv run python -m agents.research_harness.*": "allow",
          "git diff *": "allow",
          "git status *": "allow",
          "ls agents/research_harness/*": "allow",
          "ls papers/*": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "websearch": "allow",
        "webfetch": "allow",
        "memory_node": "allow",
        "memory_rel": "allow",
        "memory_query": "allow",
        "memory_recall": "allow",
        "memory_audit": "allow",
        "memory_status": "allow",
        "skill": "allow",
        "question": "allow"
      }
    }
  }
}
