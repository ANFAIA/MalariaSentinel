{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["agents/loops/AGENTS.md"],
  "default_agent": "supervisor",
  "permission": {
    "edit": {
      "AGENTS.md": "ask",
      ".gitignore": "ask",
      "opencode.json": "ask",
      "agents/memory/.project": "ask"
    },
    "bash": {
      "*": "allow",
      "make -f agents/memory/scripts/Makefile wipe *": "deny",
      "make -f agents/memory/scripts/Makefile set-project *": "deny",
      "*make*wipe*": "deny",
      "*make*set-project*": "deny",
      "rm *": "ask",
      "rmdir *": "ask",
      "git push *": "ask",
      "git checkout *": "ask"
    },
    "webfetch": "allow",
    "todowrite": "allow",
    "question": "allow",
    "memory_node": "ask",
    "memory_rel": "ask",
    "memory_query": "allow",
    "memory_audit": "allow",
    "memory_seed": "ask",
    "memory_status": "allow",
    "external_directory": "ask"
  },
  "agent": {
    "supervisor": {
      "description": "Primary orchestrator. Delegates to loops and subagents, isolates edit-work via the gitagent skill. Plan-like baseline.",
      "permission": {
        "*": "deny",
        "task": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash":{
          "*": "deny",
          "gitagents *": "allow"
        }
      }
    }
  }
}
