# Neo4j (Graphiti backend)
# neo4j-cli reads this file automatically when run from `memory/`.
# Copy to memory/.env and fill in real values. The real file is gitignored.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_local_dev_only

# LLM provider for Graphiti entity extraction (pick one).
# Graphiti default is OpenAI; swap to anthropic/google-genai/ollama via code.
OPENAI_API_KEY=
# MODEL_NAME=gpt-4o-mini

# Optional: Anthropic / Gemini / Ollama
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# Graphiti project namespace — all episodes for this project land here.
# Change per project to keep knowledge isolated.
GRAPHITI_GROUP_ID=malariasentinel

# Disable anonymous telemetry
GRAPHITI_TELEMETRY_ENABLED=false

# Concurrency for Graphiti extraction pipeline (lower = fewer rate-limit errors)
SEMAPHORE_LIMIT=5
