# Python
__pycache__/
*.pyc
*.pyo
.venv/
.python-version

# Heavy datasets (re-downloadable via scripts/restore_data.py)
#   DwC occurrence files + raw archives (kept out: ~80 MB of text + zips)
data/**/*.txt
data/**/*.zip
data/pasteur_anopheles.zip
data/occurrence.txt
#   SRTM / DEM rasters (kept out: ~480 MB of .tif)
terrain/**/*.tif
runs/layers/*.tif
runs/layers/*.zip

# Experiment artifacts (regenerable from the pipeline)
runs/
*.pt
*.npz
*.log

# Per-machine / per-project state for the agents/memory module
agents/memory/.project
agents/memory/runtime/.env
agents/memory/seed/*.yaml

# macOS
.DS_Store
**/.DS_Store

# Editors
.vscode/
